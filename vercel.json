{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    { "source": "/assets/:path*",  "destination": "/Public/assets/:path*" },
    { "source": "/uploads/:path*", "destination": "/Public/uploads/:path*" },
    { "source": "/(.*)", "destination": "/api/index.php" }
  ]
}